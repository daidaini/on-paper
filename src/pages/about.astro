---
import InnerLayout from '../layouts/InnerLayout.astro';
import Pullquote from '../components/Pullquote.astro';
import { getEntry, render } from 'astro:content';
import { withBase } from '../lib/posts';

const entry = await getEntry('about', 'colophon');
if (!entry) throw new Error('about/colophon.mdx not found');
const { Content } = await render(entry);
const d = entry.data;
---
<InnerLayout
  title={`${d.title} · 纸上生活`}
  description={d.epigraph}
  activeNav="关于"
  backHref={withBase('/')}
  backLabel="返回首页"
  footerNote="不放广告 · 不弹订阅 · 欢迎来信"
>
  <div class="about-page">
    <header class="about-head">
      <div class="about-kicker">{d.kicker}</div>
      <h1 class="about-title">{d.title}</h1>
      <p class="about-epigraph">{d.epigraph}</p>
      <div class="about-meta">
        <span>{d.metaLeft}</span><span>{d.metaRight}</span>
      </div>
    </header>

    <article class="about-body">
      <Content components={{ Pullquote }} />
    </article>

    <div class="article-signoff">
      <div class="byline">{d.signoffLeft ?? '纸上生活'}</div>
      <div class="byline-meta">
        {d.signoffRightA && <span>{d.signoffRightA}</span>}
        {d.signoffRightB && <span>{d.signoffRightB}</span>}
      </div>
    </div>

    {d.endNote && (
      <div class="article-end-note">—— {d.endNote}</div>
    )}
  </div>
</InnerLayout>

---
import BaseLayout from './BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  activeNav?: '文章' | '归档' | '关于';
  backHref?: string;
  backLabel?: string;
  footerNote?: string;
}

const {
  title,
  description,
  activeNav = '文章',
  backHref = '/',
  backLabel = '返回目录',
  footerNote = '不放广告 · 不弹订阅 · 慢慢读',
} = Astro.props;
---
<BaseLayout title={title} description={description}>
  <Topbar backHref={backHref} backLabel={backLabel} active={activeNav} />
  <slot />
  <Footer note={footerNote} />
</BaseLayout>

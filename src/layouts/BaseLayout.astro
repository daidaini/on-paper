---
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/masthead.css';
import '../styles/article.css';
import '../styles/archive.css';
import { withBase } from '../lib/posts';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '纸上生活 · life on paper',
  description = '一位夜里写字的人，关于阅读、思考、时间与城市的随笔。',
} = Astro.props;

const faviconHref = withBase('/favicon.svg');
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..600&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..600;1,8..60,300..500&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page">
      <slot />
    </div>
  </body>
</html>

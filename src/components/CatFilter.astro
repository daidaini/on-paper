---
interface Props {
  categories: { name: string; count: number }[];
  totalLabel?: string;
  total: number;
}

const { categories, totalLabel = '全部', total } = Astro.props;
---
<nav class="cat-filter">
  <a href="#" class="cat active" data-target="all">{totalLabel} <span class="count">{total}</span></a>
  {categories.map((c) => (
    <a href="#" class="cat" data-target={c.name}>
      {c.name} <span class="count">{c.count}</span>
    </a>
  ))}
</nav>

<script is:inline>
  (function () {
    document.addEventListener('click', function (e) {
      var target = e.target;
      while (target && target !== document.body && !(target.classList && target.classList.contains('cat'))) {
        target = target.parentNode;
      }
      if (!target || target === document.body) return;
      if (!target.classList.contains('cat')) return;
      e.preventDefault();

      var key = target.dataset.target;
      document.querySelectorAll('.cat-filter .cat').forEach(function (c) {
        c.classList.toggle('active', c === target);
      });

      document.querySelectorAll('.archive-row').forEach(function (r) {
        var show = key === 'all' || r.dataset.cat === key;
        r.style.display = show ? '' : 'none';
      });

      document.querySelectorAll('[data-year-block]').forEach(function (block) {
        var visible = 0;
        block.querySelectorAll('.archive-row').forEach(function (r) {
          if (r.style.display !== 'none') visible++;
        });
        block.style.display = visible ? '' : 'none';
      });
    });
  })();
</script>

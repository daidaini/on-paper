---
import { withBase } from '../lib/posts';

interface Props {
  backHref?: string;
  backLabel?: string;
  active?: '文章' | '归档' | '关于';
}

const { backHref, backLabel = '返回目录', active = '文章' } = Astro.props;
const finalBack = backHref ?? withBase('/');

const navs: { label: string; href: string }[] = [
  { label: '文章', href: withBase('/') },
  { label: '归档', href: withBase('/archive/') },
  { label: '关于', href: withBase('/about/') },
];

const home = withBase('/');
---
<div class="article-topbar">
  <a href={finalBack} class="back">{backLabel}</a>
  <a href={home} class="wordmark">纸&nbsp;上</a>
  <div class="topbar-nav">
    {navs.map((n) => (
      <a href={n.href} class={n.label === active ? 'active' : ''}>{n.label}</a>
    ))}
  </div>
</div>
